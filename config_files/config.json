{
    "scraper": {
        "timeout": 10,
        "max_retries": 2,
        "max_concurrent": 10,
        "use_playwright": false,
        "use_selenium": false,
        "retry_without_compression": true,
        "allow_direct_fallback": false,
        "min_content_length": 500
    },
    "playwright": {
        "headless": true,
        "timeout": 30000
    },
    "selenium": {
        "headless": true,
        "timeout": 30,
        "incognito": true
    },
    "proxy": {
        "enabled": true
    }
}
